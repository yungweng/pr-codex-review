#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.1"

usage() {
  cat <<'EOF'
Usage:
  pr-codex-review <pr-number|github-pr-url> [options]

Options:
  --runs N                 Number of Codex reviewer passes. Default: 6
  --concurrency N          Reviewer passes to run at once. Default: same as --runs
  --base BRANCH            Base branch to review against. Default: PR base branch
  --dry-run                Write the aggregated comment to disk without posting it
  --keep-worktree          Keep the temporary git worktree after a successful run
  --resume-run DIR         Reuse an existing run directory and only aggregate/post
  --review-timeout DURATION
                           Kill a reviewer that runs too long. Default: 45m
  --min-successful N       Minimum reviewer outputs required to aggregate/post.
                           Default: majority of the requested runs
  --no-direnv              Skip direnv allow/exec
  --allow-envrc-change     Allow automatic direnv allow even when .envrc changed
  --version                Show version
  -h, --help               Show this help

Deprecated no-ops (now the default behavior):
  --post, --cleanup, --allow-base-drift

Examples:
  pr-codex-review 123
  pr-codex-review https://github.com/owner/repo/pull/123 --runs 8 --dry-run
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

PR_URL=""
RUNS=6
RUNS_SET=0
CONCURRENCY=""
BASE_BRANCH=""
POST=1
CLEANUP=1
RESUME_RUN=""
USE_DIRENV=1
ALLOW_ENVRC_CHANGE=0
REVIEW_TIMEOUT="45m"
MIN_SUCCESSFUL=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --runs)
      RUNS="${2:-}"
      RUNS_SET=1
      shift 2
      ;;
    --runs=*)
      RUNS="${1#*=}"
      RUNS_SET=1
      shift
      ;;
    --concurrency)
      CONCURRENCY="${2:-}"
      shift 2
      ;;
    --concurrency=*)
      CONCURRENCY="${1#*=}"
      shift
      ;;
    --base)
      BASE_BRANCH="${2:-}"
      shift 2
      ;;
    --base=*)
      BASE_BRANCH="${1#*=}"
      shift
      ;;
    --dry-run)
      POST=0
      shift
      ;;
    --keep-worktree)
      CLEANUP=0
      shift
      ;;
    --post|--cleanup|--allow-base-drift)
      # Deprecated no-ops: this is the default behavior now.
      shift
      ;;
    --resume-run)
      RESUME_RUN="${2:-}"
      shift 2
      ;;
    --resume-run=*)
      RESUME_RUN="${1#*=}"
      shift
      ;;
    --review-timeout)
      REVIEW_TIMEOUT="${2:-}"
      shift 2
      ;;
    --review-timeout=*)
      REVIEW_TIMEOUT="${1#*=}"
      shift
      ;;
    --min-successful)
      MIN_SUCCESSFUL="${2:-}"
      shift 2
      ;;
    --min-successful=*)
      MIN_SUCCESSFUL="${1#*=}"
      shift
      ;;
    --no-direnv)
      USE_DIRENV=0
      shift
      ;;
    --allow-envrc-change)
      ALLOW_ENVRC_CHANGE=1
      shift
      ;;
    --version)
      echo "pr-codex-review $VERSION"
      exit 0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      if [ -n "$PR_URL" ]; then
        die "only one PR URL is supported"
      fi
      PR_URL="$1"
      shift
      ;;
  esac
done

[ -n "$PR_URL" ] || { usage; exit 1; }
[[ "$RUNS" =~ ^[0-9]+$ ]] || die "--runs must be a number"
[ -n "$CONCURRENCY" ] || CONCURRENCY="$RUNS"
[[ "$CONCURRENCY" =~ ^[0-9]+$ ]] || die "--concurrency must be a number"
[ -z "$MIN_SUCCESSFUL" ] || [[ "$MIN_SUCCESSFUL" =~ ^[0-9]+$ ]] || die "--min-successful must be a number"
[ "$RUNS" -ge 1 ] || die "--runs must be >= 1"
[ "$RUNS" -le 12 ] || die "--runs must be <= 12"
[ "$CONCURRENCY" -ge 1 ] || die "--concurrency must be >= 1"
[ -z "$MIN_SUCCESSFUL" ] || [ "$MIN_SUCCESSFUL" -ge 1 ] || die "--min-successful must be >= 1"

duration_to_seconds() {
  local value="$1"
  if [[ "$value" =~ ^[0-9]+$ ]]; then
    echo "$value"
  elif [[ "$value" =~ ^([0-9]+)s$ ]]; then
    echo "${BASH_REMATCH[1]}"
  elif [[ "$value" =~ ^([0-9]+)m$ ]]; then
    echo "$((BASH_REMATCH[1] * 60))"
  elif [[ "$value" =~ ^([0-9]+)h$ ]]; then
    echo "$((BASH_REMATCH[1] * 3600))"
  else
    die "--review-timeout must be seconds or a duration like 30m, 45m, 1h, or 0"
  fi
}

REVIEW_TIMEOUT_SECONDS="$(duration_to_seconds "$REVIEW_TIMEOUT")"

need gh
need git
need jq
need codex
if [ "$USE_DIRENV" -eq 1 ]; then
  need direnv
fi

C_GREEN=""
C_RED=""
C_DIM=""
C_BOLD=""
C_RESET=""
if [ -t 1 ] && [ -n "${TERM:-}" ] && command -v tput >/dev/null 2>&1; then
  C_GREEN="$(tput setaf 2 2>/dev/null || true)"
  C_RED="$(tput setaf 1 2>/dev/null || true)"
  C_DIM="$(tput dim 2>/dev/null || true)"
  C_BOLD="$(tput bold 2>/dev/null || true)"
  C_RESET="$(tput sgr0 2>/dev/null || true)"
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || die "run from inside the target git repository"
CURRENT_REPO="$(gh repo view --json nameWithOwner -q .nameWithOwner)"

if [[ "$PR_URL" =~ ^[0-9]+$ ]]; then
  URL_REPO="$CURRENT_REPO"
  URL_PR_NUMBER="$PR_URL"
elif [[ "$PR_URL" =~ ^https://github.com/([^/]+/[^/]+)/pull/([0-9]+) ]]; then
  URL_REPO="${BASH_REMATCH[1]}"
  URL_PR_NUMBER="${BASH_REMATCH[2]}"
else
  die "expected a PR number or a GitHub PR URL like https://github.com/owner/repo/pull/123"
fi

[ "$URL_REPO" = "$CURRENT_REPO" ] || die "PR URL is for $URL_REPO, but current checkout is $CURRENT_REPO"

META="$(gh pr view "$URL_PR_NUMBER" --json number,title,author,baseRefName,baseRefOid,headRefName,headRefOid,isDraft,url)"
PR_NUMBER="$(jq -r '.number' <<<"$META")"
PR_TITLE="$(jq -r '.title' <<<"$META")"
AUTHOR_LOGIN="$(jq -r '.author.login' <<<"$META")"
PR_BASE_BRANCH="$(jq -r '.baseRefName' <<<"$META")"
INITIAL_BASE_SHA="$(jq -r '.baseRefOid' <<<"$META")"
INITIAL_HEAD_SHA="$(jq -r '.headRefOid' <<<"$META")"
IS_DRAFT="$(jq -r '.isDraft' <<<"$META")"
PR_URL="$(jq -r '.url' <<<"$META")"

if [ -z "$BASE_BRANCH" ]; then
  BASE_BRANCH="$PR_BASE_BRANCH"
elif [ "$PR_BASE_BRANCH" != "$BASE_BRANCH" ]; then
  echo "warning: PR base is '$PR_BASE_BRANCH', but reviewing against '$BASE_BRANCH'" >&2
fi

RUN_ID="$(date +%Y%m%d-%H%M%S)"
SAFE_REPO="${CURRENT_REPO//\//-}"
BASE_REF="origin/$BASE_BRANCH"
if [ -n "$RESUME_RUN" ]; then
  RUN_ROOT="${RESUME_RUN%/}"
else
  RUN_ROOT="$HOME/.cache/pr-codex-review/$SAFE_REPO-pr-$PR_NUMBER-$RUN_ID"
fi
OUT_DIR="$RUN_ROOT/output"
WORKTREE="$RUN_ROOT/worktree"
mkdir -p "$OUT_DIR"

GC_REMOVED=0
while IFS= read -r old_dir; do
  [ "$old_dir" = "$RUN_ROOT" ] && continue
  rm -rf "$old_dir"
  GC_REMOVED=$((GC_REMOVED + 1))
done < <(find "$HOME/.cache/pr-codex-review" -mindepth 1 -maxdepth 1 -type d -mtime +7 2>/dev/null)
git -C "$REPO_ROOT" worktree prune >/dev/null 2>&1 || true
if [ "$GC_REMOVED" -gt 0 ]; then
  echo "${C_DIM}gc: removed $GC_REMOVED old run dir(s)${C_RESET}"
fi

echo "${C_BOLD}PR:       #$PR_NUMBER $PR_TITLE${C_RESET}"
echo "Author:   @$AUTHOR_LOGIN"
echo "Repo:     $CURRENT_REPO"
echo "Base:     $BASE_REF (GitHub reported $INITIAL_BASE_SHA)"
echo "Head:     $INITIAL_HEAD_SHA"
echo "Draft:    $IS_DRAFT"
echo "Run dir:  $RUN_ROOT"

cd "$REPO_ROOT"
if [ -n "$RESUME_RUN" ]; then
  [ -d "$OUT_DIR" ] || die "resume output directory does not exist: $OUT_DIR"
  [ -e "$WORKTREE/.git" ] || die "resume worktree does not look like a git checkout: $WORKTREE"
  if [ "$RUNS_SET" -eq 0 ]; then
    RUNS="$(find "$OUT_DIR" -maxdepth 1 -type f -name 'reviewer-*.md' | awk '/\/reviewer-[0-9]+\.md$/ { count++ } END { print count + 0 }')"
  fi
  [ "$RUNS" -ge 1 ] || die "no reviewer outputs found in $OUT_DIR"
  REVIEW_BASE_SHA="$(git -C "$WORKTREE" rev-parse "$BASE_REF")"
  INITIAL_HEAD_SHA="$(git -C "$WORKTREE" rev-parse HEAD)"
  echo "Resume:   using existing reviewer output"
  echo "Worktree: $WORKTREE"
  echo "Base reviewed: $REVIEW_BASE_SHA"
  echo "Head reviewed: $INITIAL_HEAD_SHA"
else
  git fetch -q origin "+refs/heads/$BASE_BRANCH:refs/remotes/origin/$BASE_BRANCH"
  REVIEW_BASE_SHA="$(git rev-parse "$BASE_REF")"
  echo "Fetched base: $REVIEW_BASE_SHA"
  git fetch -q origin "+pull/$PR_NUMBER/head:refs/pr-codex-review/$PR_NUMBER"
  FETCHED_HEAD_SHA="$(git rev-parse "refs/pr-codex-review/$PR_NUMBER")"
  [ "$FETCHED_HEAD_SHA" = "$INITIAL_HEAD_SHA" ] || die "fetched PR head $FETCHED_HEAD_SHA differs from GitHub metadata $INITIAL_HEAD_SHA"

  git worktree add --quiet --detach "$WORKTREE" "$FETCHED_HEAD_SHA"
  echo "Worktree: $WORKTREE"
fi

cleanup() {
  local rc=$?
  # Keep the worktree on failure so --resume-run can pick the run back up.
  if [ "$rc" -eq 0 ] && [ "$CLEANUP" -eq 1 ] && [ -d "$WORKTREE" ]; then
    git -C "$REPO_ROOT" worktree remove "$WORKTREE" --force >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

if [ "$USE_DIRENV" -eq 1 ] && find "$WORKTREE" -name .envrc -print -quit | grep -q .; then
  ENVRC_DIFF="$(git -C "$WORKTREE" diff --name-only "$BASE_REF"...HEAD -- .envrc ':(glob)**/.envrc' || true)"
  if [ -n "$ENVRC_DIFF" ] && [ "$ALLOW_ENVRC_CHANGE" -ne 1 ]; then
    echo "Refusing automatic direnv allow because this PR changes:" >&2
    echo "$ENVRC_DIFF" >&2
    echo "Review the .envrc change manually, then rerun with --allow-envrc-change if it is safe." >&2
    exit 2
  fi
  (cd "$WORKTREE" && direnv allow)
  echo "direnv:   allowed"
fi

format_duration() {
  local total="$1"
  printf '%dm%02ds' "$((total / 60))" "$((total % 60))"
}

run_reviewer() {
  local idx="$1"
  local out="$OUT_DIR/reviewer-$idx.md"
  local log="$OUT_DIR/reviewer-$idx.log"
  local started elapsed rank
  echo "${C_DIM}reviewer-$idx: start${C_RESET}"
  started="$(date +%s)"
  if run_with_timeout "$REVIEW_TIMEOUT_SECONDS" "$REVIEW_TIMEOUT" run_codex_review "$out" >"$log" 2>&1; then
    elapsed="$(( $(date +%s) - started ))"
    # Claim the lowest free rank atomically; counting output files races
    # when two reviewers finish at the same moment.
    rank=1
    while ! mkdir "$OUT_DIR/.done-$rank" 2>/dev/null; do
      rank=$((rank + 1))
    done
    echo "${C_GREEN}reviewer-$idx: done in $(format_duration "$elapsed") [$rank/$RUNS]${C_RESET}"
  else
    local rc=$?
    rm -f "$out"
    elapsed="$(( $(date +%s) - started ))"
    echo "${C_RED}reviewer-$idx: failed with exit $rc after $(format_duration "$elapsed") -> $log${C_RESET}" >&2
    return "$rc"
  fi
}

run_codex_review() {
  local out="$1"
  if [ "$USE_DIRENV" -eq 1 ]; then
    (cd "$WORKTREE" && direnv exec "$WORKTREE" codex exec review --base "$BASE_REF" --ephemeral -o "$out")
  else
    (cd "$WORKTREE" && codex exec review --base "$BASE_REF" --ephemeral -o "$out")
  fi
}

child_pids() {
  local pid="$1"
  ps -axo pid=,ppid= | awk -v p="$pid" '$2 == p { print $1 }'
}

kill_tree() {
  local pid="$1"
  local children child
  children="$(child_pids "$pid" || true)"
  for child in $children; do
    kill_tree "$child"
  done
  kill -TERM "$pid" 2>/dev/null || true
}

force_kill_tree() {
  local pid="$1"
  local children child
  children="$(child_pids "$pid" || true)"
  for child in $children; do
    force_kill_tree "$child"
  done
  kill -KILL "$pid" 2>/dev/null || true
}

run_with_timeout() {
  local seconds="$1"
  local label="$2"
  shift 2
  if [ "$seconds" -eq 0 ]; then
    "$@"
    return
  fi

  "$@" &
  local child="$!"
  local elapsed=0
  while kill -0 "$child" 2>/dev/null; do
    if [ "$elapsed" -ge "$seconds" ]; then
      echo "error: reviewer timed out after $label; terminating process tree rooted at $child" >&2
      kill_tree "$child"
      sleep 2
      if kill -0 "$child" 2>/dev/null; then
        force_kill_tree "$child"
      fi
      wait "$child" 2>/dev/null || true
      return 124
    fi
    sleep 5
    elapsed=$((elapsed + 5))
  done
  wait "$child"
}

reviewer_indices() {
  find "$OUT_DIR" -maxdepth 1 -type f -name 'reviewer-*.md' \
    | sed -nE 's#.*/reviewer-([0-9]+)\.md$#\1#p' \
    | sort -n
}

if [ -z "$RESUME_RUN" ]; then
  FAILED=0
  batch=()
  for idx in $(seq 1 "$RUNS"); do
    run_reviewer "$idx" &
    batch+=("$!")
    if [ "${#batch[@]}" -ge "$CONCURRENCY" ]; then
      for pid in "${batch[@]}"; do
        wait "$pid" || FAILED=1
      done
      batch=()
    fi
  done
  # Bash 3.2 aborts on "${batch[@]}" when the array is empty under set -u.
  if [ "${#batch[@]}" -gt 0 ]; then
    for pid in "${batch[@]}"; do
      wait "$pid" || FAILED=1
    done
  fi

fi

REVIEWER_INDICES=()
while IFS= read -r idx; do
  REVIEWER_INDICES+=("$idx")
done < <(reviewer_indices)
SUCCESSFUL_REVIEWS="${#REVIEWER_INDICES[@]}"
if [ -z "$MIN_SUCCESSFUL" ]; then
  MIN_SUCCESSFUL="$(( (RUNS + 1) / 2 ))"
fi
if [ "$SUCCESSFUL_REVIEWS" -lt "$MIN_SUCCESSFUL" ]; then
  echo "Only $SUCCESSFUL_REVIEWS reviewer output(s) available; need $MIN_SUCCESSFUL." >&2
  echo "Check logs in $OUT_DIR." >&2
  exit 1
fi
if [ "${FAILED:-0}" -ne 0 ]; then
  echo "warning: one or more reviewers failed; continuing with $SUCCESSFUL_REVIEWS reviewer output(s)." >&2
fi

LATEST_BASE_SHA="$(git ls-remote origin "refs/heads/$BASE_BRANCH" | awk '{print $1}')"
LATEST_HEAD_SHA="$(git ls-remote origin "refs/pull/$PR_NUMBER/head" | awk '{print $1}')"
[ -n "$LATEST_BASE_SHA" ] || die "could not resolve remote base ref refs/heads/$BASE_BRANCH"
[ -n "$LATEST_HEAD_SHA" ] || die "could not resolve remote PR ref refs/pull/$PR_NUMBER/head"
BASE_DRIFT_NOTE=""
if [ "$LATEST_HEAD_SHA" != "$INITIAL_HEAD_SHA" ]; then
  echo "PR head changed during review; refusing to aggregate/post stale findings." >&2
  echo "Reviewed base/head: $REVIEW_BASE_SHA / $INITIAL_HEAD_SHA" >&2
  echo "Latest  base/head: $LATEST_BASE_SHA / $LATEST_HEAD_SHA" >&2
  exit 3
fi
if [ "$LATEST_BASE_SHA" != "$REVIEW_BASE_SHA" ]; then
  BASE_DRIFT_NOTE="Base branch moved after review: reviewed $REVIEW_BASE_SHA, latest $LATEST_BASE_SHA. The PR head stayed the same."
  echo "warning: $BASE_DRIFT_NOTE" >&2
fi

ALL_REVIEWERS="$OUT_DIR/all-reviewers.md"
FINAL_COMMENT="$OUT_DIR/final-pr-comment.md"
{
  echo "# Reviewer Outputs"
  echo
  for idx in "${REVIEWER_INDICES[@]}"; do
    echo "## Reviewer $idx"
    echo
    [ -f "$OUT_DIR/reviewer-$idx.md" ] || die "missing reviewer output: $OUT_DIR/reviewer-$idx.md"
    cat "$OUT_DIR/reviewer-$idx.md"
    echo
  done
} > "$ALL_REVIEWERS"

AGG_PROMPT="$(cat <<EOF
Write the exact Markdown body for a GitHub PR comment and tag the creator of the PR directly. Be nice. Aggregate these findings and use them as input for the PR review.

Important execution rules:
- Do not post the comment.
- Do not run gh, git, curl, xh, or any other command.
- Do not use tools.
- Return only the Markdown comment body.
- Do not wrap the answer in a code fence.

PR: $PR_URL
Title: $PR_TITLE
Author: @$AUTHOR_LOGIN
Base: $BASE_REF
Base SHA reviewed: $REVIEW_BASE_SHA
Head SHA: $INITIAL_HEAD_SHA
Base drift note: ${BASE_DRIFT_NOTE:-none}

Rules:
- Address @$AUTHOR_LOGIN directly near the top.
- Be friendly, but do not dilute real issues.
- Deduplicate overlapping findings.
- Do not invent findings that are not present in the reviewer outputs.
- Keep only findings grounded in reviewer evidence.
- Prefer this structure: Summary, Blockers, Critical, Suggestions, Questions.
- If there are no blockers or critical issues, say that clearly.
- Do not mention internal reviewer count, Codex sessions, or automation details.
- Keep the comment concise enough for a GitHub PR discussion.
EOF
)"

run_aggregator() {
  if [ "$USE_DIRENV" -eq 1 ]; then
    (cd "$WORKTREE" && direnv exec "$WORKTREE" codex exec --sandbox read-only --ephemeral -o "$FINAL_COMMENT" "$AGG_PROMPT" < "$ALL_REVIEWERS") >"$OUT_DIR/aggregator.log" 2>&1
  else
    (cd "$WORKTREE" && codex exec --sandbox read-only --ephemeral -o "$FINAL_COMMENT" "$AGG_PROMPT" < "$ALL_REVIEWERS") >"$OUT_DIR/aggregator.log" 2>&1
  fi
}

aggregator_output_valid() {
  if head -n 1 "$FINAL_COMMENT" | grep -Eq '^```'; then
    echo "Aggregator wrapped the comment in a code fence." >&2
    return 1
  fi
  if grep -Eiq 'I tried to post|gh pr comment|api\.github\.com|exact comment I prepared' "$FINAL_COMMENT"; then
    echo "Aggregator produced meta-output instead of a PR comment." >&2
    return 1
  fi
}

echo "${C_DIM}aggregator: combining $SUCCESSFUL_REVIEWS reviewer output(s)...${C_RESET}"
AGG_OK=0
for attempt in 1 2; do
  run_aggregator
  if aggregator_output_valid; then
    AGG_OK=1
    break
  fi
  if [ "$attempt" -eq 1 ]; then
    echo "aggregator: attempt 1 produced invalid output, retrying..." >&2
  fi
done
if [ "$AGG_OK" -ne 1 ]; then
  echo "Aggregator output still invalid after 2 attempts; refusing to post. See $FINAL_COMMENT" >&2
  exit 4
fi

echo
if [ -t 1 ] && command -v glow >/dev/null 2>&1; then
  glow "$FINAL_COMMENT" || cat "$FINAL_COMMENT"
else
  cat "$FINAL_COMMENT"
  echo
fi

echo "${C_DIM}----------------------------------------${C_RESET}"
if [ "$SUCCESSFUL_REVIEWS" -eq "$RUNS" ]; then
  echo "Reviewers: $SUCCESSFUL_REVIEWS/$RUNS succeeded"
else
  echo "Reviewers: $SUCCESSFUL_REVIEWS/$RUNS succeeded ${C_RED}($((RUNS - SUCCESSFUL_REVIEWS)) failed)${C_RESET}"
fi
echo "Comment:   $FINAL_COMMENT"
if [ "$POST" -eq 1 ]; then
  COMMENT_URL="$(gh pr comment "$URL_PR_NUMBER" --body-file "$FINAL_COMMENT")"
  echo "Posted:    ${C_GREEN}yes${C_RESET} -> ${COMMENT_URL:-PR #$PR_NUMBER}"
else
  echo "Posted:    no (dry run; post with: gh pr comment $URL_PR_NUMBER --body-file $FINAL_COMMENT)"
fi
